# Neon Postgres connection string
NEON_URL=postgresql://user:password@ep-example.neon.tech/torchdocs?sslmode=require

# Primary LLM provider — Gemini Flash, has a genuine free tier (no card needed)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Comparison / fallback provider — Claude Haiku (paid, no persistent free tier)
ANTHROPIC_API_KEY=

# Langfuse (optional until M4)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
