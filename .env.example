# Neon Postgres connection string (holds vectors + pointers, never page text)
NEON_URL=postgresql://user:password@ep-example.neon.tech/torchdocs?sslmode=require

# --- Generation provider -----------------------------------------------------
# Which LLM answers. If unset, it's auto-detected from whichever key is present
# (openai-compat → anthropic → gemini). The free-tier deployment uses
# openai-compat; set this only to force a specific provider.
TORCHDOCS_PROVIDER=openai-compat

# Any OpenAI-compatible host serving open models cheaply on US/EU servers
# (OpenRouter: https://openrouter.ai/api/v1 ; DeepInfra: https://api.deepinfra.com/v1/openai ; Nebius, ...)
# Base URL must include the scheme (https://...) — a bare host fails fast.
OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPAT_API_KEY=
# Comma-separated = fallback chain: if one model is rate-limited/retired, the
# next is tried. Use REAL slugs for your host — for OpenRouter these are
# `org/model:free` (verify at https://openrouter.ai/models?max_price=0). A
# made-up slug makes every call 404, which looks like "OpenRouter is broken".
# Defaults to the chain below if unset.
TORCHDOCS_OPENAI_COMPAT_MODEL=deepseek/deepseek-chat-v3-0324:free,meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free

# Anthropic — the paid production path (higher-quality generation).
ANTHROPIC_API_KEY=
# TORCHDOCS_ANTHROPIC_MODEL=claude-sonnet-5

# Gemini — free tier, used for eval/dev generation only.
GEMINI_API_KEY=
# TORCHDOCS_GEMINI_MODEL=gemini-2.5-flash

# --- Indexing ----------------------------------------------------------------
# Embeddings run locally on CPU (no API quota). Changing the model re-embeds
# the whole corpus (dimension change rebuilds the chunks table automatically).
# TORCHDOCS_EMBED_MODEL=BAAI/bge-small-en-v1.5

# When no bundled _corpus/ snapshot is present, hydrate cited pages live from
# docs.pytorch.org. Set to 0 to require the snapshot instead.
# TORCHDOCS_LIVE_HYDRATE=1

# --- App ---------------------------------------------------------------------
# Port the Gradio app binds to (Hugging Face Spaces sets this).
# PORT=7860

# How many questions the app answers at once. A request is almost all I/O
# (LLM + Neon), so overlapping many is cheap and keeps users from queueing.
# Raise on a bigger Space / paid LLM key; lower if the LLM key is tightly
# rate-limited.
# TORCHDOCS_CONCURRENCY=16

# Max concurrent Neon connections in the app's shared pool. A request holds one
# only for the brief reads in retrieve(), so this can sit well below
# TORCHDOCS_CONCURRENCY; keep it at or under your Neon plan's connection limit.
# TORCHDOCS_DB_POOL=8

# Langfuse (optional, M4 — tracing/eval). Unused until then.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
