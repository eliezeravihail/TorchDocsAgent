# Neon Postgres connection string
NEON_URL=postgresql://user:password@ep-example.neon.tech/torchdocs?sslmode=require

# Gemini API key — covers BOTH generation (gemini-2.5-flash) and embeddings
# (gemini-embedding-001) on the free tier. Get one at aistudio.google.com.
GEMINI_API_KEY=

# Optional until M3 (LiteLLM): paid providers for higher-quality generation
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provider for generation: gemini (default) | anthropic
TORCHDOCS_PROVIDER=gemini

# Langfuse (optional until M4)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
